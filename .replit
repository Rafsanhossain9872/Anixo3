modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind", "0.0.0.0:5000", "main:app"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Python Scraper"

[[workflows.workflow]]
name = "Python Scraper"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 backup_scraper.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "FLASK_VANILLA_JS"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3000

[[ports]]
localPort = 9000
externalPort = 9000

[[ports]]
localPort = 19704
externalPort = 80

[userenv]

[userenv.shared]
VITE_TURNSTILE_SITE_KEY = "0x4AAAAAAADRFK1iJghlMH6Ms"

[nix]
channel = "stable-25_05"
packages = ["openssl", "postgresql"]
